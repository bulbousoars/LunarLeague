# Production-oriented defaults — copy to `.env` on your VPS and replace every placeholder.
# Example: cp deploy/.env.production.example deploy/.env
#
# Do NOT commit deploy/.env (gitignored).

# --- Public URLs (must match the HTTPS domain users open in the browser) ---
PUBLIC_WEB_URL=https://lunarleague.dugganco.com
PUBLIC_API_URL=https://lunarleague.dugganco.com

# --- Postgres ---
POSTGRES_DB=lunarleague
POSTGRES_USER=lunarleague
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

REDIS_PORT=6379

# --- API ---
API_PORT=8000
API_BIND=0.0.0.0
API_SECRET_KEY=replace-with-32-plus-random-bytes-minimum-length-secret
API_LOG_LEVEL=info
API_ENV=prod

DATA_PROVIDER=sleeper
SPORTSDATAIO_API_KEY=

# --- Outbound email (pick one provider; examples below) ---
# Port 587: STARTTLS is automatic. Port 465: implicit TLS is automatic.
# Never use SMTP_HOST=mailhog in production unless Mailhog runs on that stack (dev only).

# --- Example A — Resend (https://resend.com/docs/send-with-smtp) ---
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USERNAME=resend
# SMTP_PASSWORD=re_xxxxxxxx
# SMTP_FROM=Lunar League <onboarding@resend.dev>

# --- Example B — SendGrid ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxxxx
# SMTP_FROM=Lunar League <verified-sender@yourdomain.com>

# --- Example C — Mailgun EU/US SMTP ---
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USERNAME=postmaster@YOUR_DOMAIN.mailgun.org
# SMTP_PASSWORD=your-mailgun-smtp-password
# SMTP_FROM=Lunar League <noreply@yourdomain.com>

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Lunar League <noreply@yourdomain.com>
SMTP_ALLOW_PLAINTEXT=false

# --- Web (must match PUBLIC_* for browser API/WebSocket calls) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=https://lunarleague.dugganco.com
NEXT_PUBLIC_WS_URL=wss://lunarleague.dugganco.com

MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
ADMINER_PORT=8080

CADDY_DOMAIN=lunarleague.dugganco.com
CADDY_EMAIL=you@yourdomain.com
