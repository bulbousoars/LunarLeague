# Copy to /etc/lunarleague/auto-deploy.env (mode 640, root:root or root:deploy).
# Values here are NOT secrets — keep SMTP/API keys only in deploy/.env (gitignored).

# Git branch to track (must exist on origin).
LUNARLEAGUE_DEPLOY_BRANCH=main

# Optional: merge deploy/docker-compose.<name>.yml (e.g. homelab bind mounts).
LUNARLEAGUE_COMPOSE_OVERLAY=realestate
