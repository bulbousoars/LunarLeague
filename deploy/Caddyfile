# Homelab / Traefik: TLS usually terminates at the edge. This stack serves HTTP on
# :80 only and proxies to api + web using the same ports they listen on inside Docker.
# Set API_PORT / WEB_PORT in deploy/.env (defaults 8000 / 3000).
{
	auto_https off
}

:80 {
	encode gzip zstd

	@api path /v1/* /healthz /ws /ws/*
	handle @api {
		reverse_proxy api:{$API_PORT}
	}

	handle {
		reverse_proxy web:{$WEB_PORT}
	}
}
