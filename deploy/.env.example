# Copy to deploy/.env and edit to taste.

# --- Public URLs (used in email links + CORS) ---
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# --- Postgres ---
POSTGRES_DB=lunarleague
POSTGRES_USER=lunarleague
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- API ---
API_PORT=8000
API_BIND=0.0.0.0
# 32+ random bytes, used to sign sessions + magic-link tokens
API_SECRET_KEY=changeme-please-32-byte-random-string-xxx
API_LOG_LEVEL=info
API_ENV=dev

# --- Data provider ---
# sleeper = default (free NFL+NBA + MLB via MLB Stats API). sportsdataio = deferred scaffold — prefer sleeper until ROADMAP says otherwise.
DATA_PROVIDER=sleeper
SPORTSDATAIO_API_KEY=

# --- Email (magic links + digests + league-created notices) ---
# Dev (`make dev` + Mailhog): SMTP_HOST=mailhog SMTP_PORT=1025 — Mailhog UI http://localhost:8025
# Production: real SMTP (often 587 with STARTTLS — automatic; or 465 implicit TLS).
# Internal relay without STARTTLS: SMTP_ALLOW_PLAINTEXT=true (avoid on public Internet).
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=Lunar League <no-reply@lunarleague.local>
SMTP_ALLOW_PLAINTEXT=false

# --- Web ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Mailhog (dev compose only; prod uses a real SMTP relay) ---
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# --- Adminer (dev only) ---
ADMINER_PORT=8080

# --- Caddy (prod) ---
CADDY_DOMAIN=fantasy.example.com
CADDY_EMAIL=you@example.com
